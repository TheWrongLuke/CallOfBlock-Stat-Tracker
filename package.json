{
    "name": "call-of-block-stat-tracker",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "description": "Call of Block 2 community hub, stat tracker, profiles, playtests, and support tickets.",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "dev": "node scripts/static-server.mjs --root=. --port=4173",
        "build": "node scripts/build.mjs",
        "preview": "node scripts/static-server.mjs --root=dist --port=4174",
        "lint": "eslint --config config/eslint.config.js src scripts tests config",
        "stylelint": "stylelint --config config/stylelint.config.js assets/css/styles.css",
        "format": "prettier --config config/prettier.config.js --write \"src/*/**/*.js\" \"scripts/**/*.mjs\" \"tests/**/*.js\" \"config/**/*.{js,json}\" package.json \".github/**/*.yml\" public/site.webmanifest",
        "format:check": "prettier --config config/prettier.config.js --check \"src/*/**/*.js\" \"scripts/**/*.mjs\" \"tests/**/*.js\" \"config/**/*.{js,json}\" package.json \".github/**/*.yml\" public/site.webmanifest",
        "test": "vitest run --config config/vitest.config.js",
        "test:e2e": "npm run build && playwright test --config config/playwright.config.js"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.61.1",
        "eslint": "^10.7.0",
        "globals": "^17.7.0",
        "prettier": "^3.9.5",
        "stylelint": "^17.14.0",
        "vitest": "^4.1.10"
    }
}
